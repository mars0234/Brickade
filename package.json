{
  "name": "brickade",
  "version": "1.0.0",
  "description": "Real-time online block-stacking battle game",
  "main": "build.js",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "deploy": "node build.js",
    "build:ai": "emcc src/ai.cpp -O3 --bind -s ALLOW_MEMORY_GROWTH=1 -o src/brickade_ai.js",
    "test:ai": "node tools/ai_test.js ./test_ai.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mars0234/Brickade.git"
  },
  "keywords": [
    "html5-game",
    "browser-game",
    "puzzle",
    "multiplayer",
    "webrtc",
    "pwa"
  ],
  "author": "Mars Wang",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mars0234/Brickade/issues"
  },
  "homepage": "https://github.com/mars0234/Brickade#readme",
  "devDependencies": {
    "firebase-admin": "^13.9.0",
    "javascript-obfuscator": "^5.4.1"
  }
}
